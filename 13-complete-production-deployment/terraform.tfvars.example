# ==============================================================================
# terraform.tfvars.example
#
# Copy to terraform.tfvars and adjust as needed.
# All values match the defaults in variables.tf — only override what changes.
#
#   cp terraform.tfvars.example terraform.tfvars
# ==============================================================================

# ------------------------------------------------------------------------------
# AWS Provider
# ------------------------------------------------------------------------------
aws_region = "ap-south-1"

# aws_profile = "sarowar-ostad"  # uncomment when running locally
                                  # leave commented (or omit) on EC2 with instance role

# ------------------------------------------------------------------------------
# Project Identity
# ------------------------------------------------------------------------------
project_name = "bmi-health-tracker"
environment  = "prod"

# ------------------------------------------------------------------------------
# Compute
# ------------------------------------------------------------------------------
frontend_instance_type = "t3.medium"
backend_instance_type  = "t3.large"

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
db_instance_class = "db.t3.medium"
multi_az          = true   # set false to reduce cost during testing

# ------------------------------------------------------------------------------
# Networking
# ------------------------------------------------------------------------------
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["ap-south-1a", "ap-south-1b"]

public_subnet_cidrs      = ["10.0.1.0/24", "10.0.2.0/24"]
private_app_subnet_cidrs = ["10.0.3.0/24", "10.0.4.0/24"]
private_db_subnet_cidrs  = ["10.0.5.0/24", "10.0.6.0/24"]

# ------------------------------------------------------------------------------
# DNS + TLS  (pre-provisioned — do not change unless using a different account)
# ------------------------------------------------------------------------------
certificate_arn = "arn:aws:acm:ap-south-1:388779989543:certificate/c5e5f2a5-c678-4799-b355-765c13584fe0"
hosted_zone_id  = "Z1019653XLWIJ02C53P5"
domain_name     = "bmi.ostaddevops.click"
